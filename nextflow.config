// nextflow.config
//
// Optional Nextflow layer over the existing bash engine
// (pipeline/rare_disease_vcf_annotation_pipeline.sh). This does NOT
// replace run_batch_pipeline.sh -- it's an alternative orchestrator for
// people who want Nextflow's parallelism, -resume, and reporting instead
// of the plain-bash batch runner. Both read the same sample sheet and
// the same annotation_resources.env config, so you can use either.

params {
    sample_sheet = "config/sample_sheet.tsv"
    config_env   = "config/annotation_resources.env"
    engine       = "pipeline/rare_disease_vcf_annotation_pipeline.sh"
    qc_script    = "pipeline/qc_check.py"
    outdir       = "${launchDir}/results"
    threads      = 4
}

profiles {
    // Tiny smoke-test profile -- point this at synthetic data before
    // running anything real. Mirrors the "test" profile pattern used in
    // Nextflow-native pipelines.
    test {
        params.sample_sheet = "${projectDir}/config/sample_sheet.tsv"
    }

    // Run everything inside Apptainer containers instead of relying on
    // tools being on PATH.
    apptainer {
        apptainer.enabled = true
        apptainer.autoMounts = true
    }
}

process {
    // Defaults; override per-process below or in a local config.
    cpus   = 2
    memory = '4 GB'

    withName: ANNOTATE_SAMPLE {
        cpus   = { params.threads as int }
        memory = '16 GB'
    }
    withName: QC_CHECK {
        cpus   = 1
        memory = '2 GB'
    }
}

report {
    enabled   = true
    file      = "${params.outdir}/execution_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/execution_timeline.html"
    overwrite = true
}
