#!/usr/bin/env bash
# annotation_resources.env
#
# Copy this file to config/annotation_resources.env and fill in real paths.
# This is sourced by rare_disease_vcf_annotation_pipeline.sh with `source`,
# so it must stay valid bash. One config file covers every sample/disease
# in the project — nothing here is disease-specific.
#
# Every pipeline step has a RUN_<STEP>=1 switch. Set any step to 0 if you
# don't have that database/tool installed; the engine skips it cleanly.

# ---------------------------------------------------------------------------
# Core / reference genome (required)
# ---------------------------------------------------------------------------
REF_FASTA="/home/USER/genomics_project/resources/reference/hg38.fa"

# ---------------------------------------------------------------------------
# Step 2: Ensembl VEP
# ---------------------------------------------------------------------------
RUN_VEP=1
VEP_CACHE_DIR="/home/USER/genomics_project/resources/vep_cache"
VEP_PLUGIN_DIR=""                       # optional, leave blank if unused
ALPHAMISSENSE_TSV_GZ=""                 # optional plugin data
REVEL_TSV_GZ=""                         # optional plugin data
CADD_SNV_TSV_GZ=""                      # optional plugin data
CADD_INDEL_TSV_GZ=""                    # optional plugin data

# ---------------------------------------------------------------------------
# Step 3: SnpEff (independent consequence annotation)
# ---------------------------------------------------------------------------
RUN_SNPEFF=1
SNPEFF_JAR="/home/USER/genomics_project/tools/snpEff/snpEff.jar"
SNPEFF_GENOME="GRCh38.mane.1.2.ensembl" # must match a database you've downloaded
JAVA_MEM="8g"

# ---------------------------------------------------------------------------
# Step 4: ClinVar (via SnpSift)
# ---------------------------------------------------------------------------
RUN_CLINVAR=1
CLINVAR_VCF_GZ="/home/USER/genomics_project/resources/clinvar/clinvar.chr.vcf.gz"
SNPSIFT_JAR="/home/USER/genomics_project/tools/snpEff/SnpSift.jar"
CLINVAR_INFO_FIELDS="CLNSIG,CLNREVSTAT,CLNDN,CLNDISDB,CLNHGVS,CLNVC,CLNVCSO,GENEINFO"

# ---------------------------------------------------------------------------
# Step 5: gnomAD population frequencies (optional — VEP --everything already
# pulls some gnomAD fields; this is for a separate/local gnomAD VCF)
# ---------------------------------------------------------------------------
RUN_GNOMAD=0
GNOMAD_VCF_GZ=""
GNOMAD_ANNOTATE_COLUMNS="INFO/GNOMAD_AF:=INFO/AF,INFO/GNOMAD_AC:=INFO/AC,INFO/GNOMAD_AN:=INFO/AN"

# ---------------------------------------------------------------------------
# Step 6: ClinGen dosage sensitivity (haploinsufficiency/triplosensitivity)
# ---------------------------------------------------------------------------
RUN_CLINGEN=1
CLINGEN_DOSAGE_BED_GZ="/home/USER/genomics_project/resources/clingen/clingen_dosage.hg38.bed.gz"

# ---------------------------------------------------------------------------
# Step 7: SpliceAI
# SPLICEAI_MODE = "standalone" (run the model) or "precomputed" (transfer
# scores from an existing indexed VCF)
# ---------------------------------------------------------------------------
RUN_SPLICEAI=1
SPLICEAI_MODE="standalone"
SPLICEAI_SCORES_VCF_GZ=""               # only needed if SPLICEAI_MODE=precomputed
SPLICEAI_ASSEMBLY="grch38"              # set automatically from -a, override if needed

# ---------------------------------------------------------------------------
# Step 8: MAVERICK — optional extra pathogenicity score, off by default
# ---------------------------------------------------------------------------
RUN_MAVERICK=0
MAVERICK_TSV_GZ=""
MAVERICK_COLUMNS="CHROM,POS,REF,ALT,INFO/MAVERICK_SCORE"

# ---------------------------------------------------------------------------
# Step 9: ANNOVAR
# ---------------------------------------------------------------------------
RUN_ANNOVAR=1
ANNOVAR_DIR="/home/USER/genomics_project/tools/annovar"
ANNOVAR_HUMANDB="/home/USER/genomics_project/tools/annovar/humandb"
ANNOVAR_BUILDVER="hg38"                 # set automatically from -a, override if needed
ANNOVAR_PROTOCOLS="refGene,clinvar_20240611,gnomad41_genome,dbnsfp47a"
ANNOVAR_OPERATIONS="g,f,f,f"

# ---------------------------------------------------------------------------
# Step 10: InterVar (automated ACMG/AMP classification)
# ---------------------------------------------------------------------------
RUN_INTERVAR=1
INTERVAR_DIR="/home/USER/genomics_project/tools/InterVar"

# ---------------------------------------------------------------------------
# CNV branch — Step 11: AnnotSV
# ---------------------------------------------------------------------------
RUN_ANNOTSV=1
ANNOTSV_DIR="/home/USER/genomics_project/tools/AnnotSV"

# ---------------------------------------------------------------------------
# CNV branch — Step 12: ClassifyCNV
# ---------------------------------------------------------------------------
RUN_CLASSIFYCNV=1
CLASSIFYCNV_DIR="/home/USER/genomics_project/tools/ClassifyCNV"
CLASSIFY_BUILDVER="hg38"                # set automatically from -a, override if needed

# ---------------------------------------------------------------------------
# CNV branch — Step 13: ISV-CNV (machine-learning CNV pathogenicity)
# ---------------------------------------------------------------------------
RUN_ISV_CNV=1

# ---------------------------------------------------------------------------
# CNV branch — Step 14: Horizon placeholder (only if you have a local model)
# ---------------------------------------------------------------------------
RUN_HORIZON=0
HORIZON_CMD=""                          # use {input} and {output} placeholders
